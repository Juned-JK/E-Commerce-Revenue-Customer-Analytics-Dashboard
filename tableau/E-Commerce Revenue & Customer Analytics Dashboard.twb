      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.09phsdb1mztooy10enm4p1irema0].[ctd:CustomerID:qk]&quot;' value='Total Customers' />
          <alias key='&quot;[federated.09phsdb1mztooy10enm4p1irema0].[ctd:InvoiceNo:qk]&quot;' value='Total Orders' />
          <alias key='&quot;[federated.09phsdb1mztooy10enm4p1irema0].[sum:Quantity:qk]&quot;' value='Quantity Sold' />
          <alias key='&quot;[federated.09phsdb1mztooy10enm4p1irema0].[sum:Revenue:qk]&quot;' value='Total Revenue' />
        </aliases>
      </column>
      <column caption='Average order value' datatype='real' name='[Calculation_0427174870990848]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue])/COUNTD([InvoiceNo])' />
      </column>
      <column caption='month in text' datatype='string' name='[Calculation_0427174872440833]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Month]&#13;&#10;WHEN 1 THEN &quot;January&quot;&#13;&#10;WHEN 2 THEN &quot;February&quot;&#13;&#10;WHEN 3 THEN &quot;March&quot;&#13;&#10;WHEN 4 THEN &quot;April&quot;&#13;&#10;WHEN 5 THEN &quot;May&quot;&#13;&#10;WHEN 6 THEN &quot;June&quot;&#13;&#10;WHEN 7 THEN &quot;July&quot;&#13;&#10;WHEN 8 THEN &quot;August&quot;&#13;&#10;WHEN 9 THEN &quot;September&quot;&#13;&#10;WHEN 10 THEN &quot;October&quot;&#13;&#10;WHEN 11 THEN &quot;November&quot;&#13;&#10;WHEN 12 THEN &quot;December&quot;&#13;&#10;END' />
      </column>
      <column caption='Customer Type' datatype='string' name='[Calculation_0427174876790786]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF { FIXED [CustomerID] : COUNTD([InvoiceNo]) } &gt; 1&#13;&#10;THEN &quot;Repeat Customer&quot;&#13;&#10;ELSE &quot;One-Time Customer&quot;&#13;&#10;END' />
      </column>
      <column caption='Customer Revenue' datatype='real' name='[Calculation_0427174880079876]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [CustomerID] : SUM([Revenue]) }' />
      </column>
      <column caption='Customer Segment' datatype='string' name='[Calculation_0427174880337925]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Top 10 Customers]&#13;&#10;THEN &quot;Top 10 Customers&quot;&#13;&#10;ELSE &quot;Remaining Customers&quot;&#13;&#10;END' />
      </column>
      <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column caption='Customer ID' datatype='real' name='[CustomerID]' role='dimension' type='ordinal' />
      <column datatype='integer' name='[Day]' role='dimension' type='quantitative' />
