        <zone forceUpdate='true' h='11855' id='27' type-v2='text' w='24051' x='75765' y='17294'>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Tableau Bold' fontsize='10'>📌 Key Insights</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Bold' fontsize='10'>•</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Bold'> Total revenue reached $8.91M from 18,536 orders and 4,339 customers.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Bold'>• Revenue peaked in November ($1.16M), indicating strong seasonal demand in Q4.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Bold'>• The United Kingdom generated $7.31M, contributing the majority of overall sales.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Bold'>• 65.57% of customers were repeat buyers, highlighting strong customer retention and loyalty.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Bold'>•The Top 10 customers contributed 17.26% of total revenue, indicating a small group of customers drives a significant portion of sales.</run>
          </formatted-text>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='solid' />
            <format attr='border-width' value='1' />
          </zone-style>
        </zone>
